# Skopiuj ten plik jako .env i uzupelnij swoj klucz API Claude
# Jesli uzywasz Ollama (lokalny LLM) - mozesz zostawic to pole puste

ANTHROPIC_API_KEY=twoj_klucz_api_tutaj

# Opcjonalnie: URL do lokalnego Ollama (domyslnie http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
